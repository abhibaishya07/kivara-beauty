{
      "version": 2,
      "builds": [
              {
                        "src": "client/package.json",
                        "use": "@vercel/static-build",
                        "config": { "distDir": "dist" }
              },
              {
                        "src": "server/server.js",
                        "use": "@vercel/node"
              }
      ],
      "rewrites": [
              { "source": "/api/(.*)", "destination": "/server/server.js" },
              { "source": "/assets/(.*)", "destination": "/client/assets/$1" },
              { "source": "/images/(.*)", "destination": "/client/images/$1" },
              { "source": "/favicon.svg", "destination": "/client/favicon.svg" },
              { "source": "/icons.svg", "destination": "/client/icons.svg" },
              { "source": "/(.*)", "destination": "/client/index.html" }
      ]
}
